import tkinter as tk
from tkinter import messagebox
from matplotlib.backends.backend_tkagg import FigureCanvasTkAgg
import matplotlib.pyplot as plt
import numpy as np
import sympy as sp

# ==================== Функції ====================
def plot_graph():
    eq_text = equation_entry.get()
    x = sp.symbols('x')
    try:
        expr = sp.sympify(eq_text)
        f = sp.lambdify(x, expr, modules=['numpy'])
        X = np.linspace(-10, 10, 400)
        Y = f(X)
        ax.clear()
        ax.plot(X, Y, label=f"y = {eq_text}")
        ax.legend()
        canvas.draw()
    except Exception as e:
        messagebox.showerror("Помилка", f"Не можу побудувати графік:\n{e}")


def solve_equation():
    eq_text = equation_entry.get()
    x = sp.symbols('x')
    try:
        # Автоматично перетворюємо "==" на Eq()
        if '==' in eq_text:
            left, right = eq_text.split('==')
            eq = sp.Eq(sp.sympify(left), sp.sympify(right))
        else:
            eq = sp.sympify(eq_text)

        # Розв'язуємо рівняння і беремо тільки дійсні корені
        solutions = [s.evalf() for s in sp.solve(eq, x) if s.is_real]
        messagebox.showinfo("Розв'язки", f"Розв'язки: {solutions}")
    except Exception as e:
        messagebox.showerror("Помилка", f"Не можу розв'язати рівняння:\n{e}")

import math
def calculate():
    expr_text = calc_entry.get()
    try:
        # Створюємо свою "безпечну" середу для eval
        safe_dict = {
            "abs": abs,
            "sqrt": math.sqrt,
            "root": lambda x, n: x ** (1 / n),
            "sin": lambda x: math.sin(math.radians(x)),
            "cos": lambda x: math.cos(math.radians(x)),
            "tan": lambda x: math.tan(math.radians(x)),
            "pi": math.pi,
            "e": math.e
        }
        result = eval(expr_text, {"__builtins__": None}, safe_dict)
        calc_result_var.set(str(result))
    except Exception as e:
        calc_result_var.set(f"Помилка: {e}")

